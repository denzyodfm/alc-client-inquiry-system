generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  INQUIRY_USER
  AUDITOR
  ACCOUNT_OFFICER
  AREA_TEAM_LEADER
  CREDIT_COMMITTEE
  HO_CASHIER
}

enum BranchStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum LoanStatus {
  ACTIVE
  PAID
  CLOSED
  WRITTEN_OFF
}

enum SyncStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum RemedialAssignmentStatus {
  ACTIVE
  CLOSED
}

enum RemedialVisitStatus {
  PENDING_APPROVAL
  APPROVED
  COMPLETED
  REJECTED
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(120)
  email        String   @unique @db.VarChar(160)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(INQUIRY_USER)
  allBranches  Boolean  @default(false) @map("all_branches")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  branchAccess UserBranchAccess[]
  remedialAssignments RemedialAssignment[] @relation("RemedialAssignedOfficer")
  remedialAssignedBy RemedialAssignment[] @relation("RemedialAssignedBy")
  remedialVisitsCreated RemedialVisit[] @relation("RemedialVisitCreatedBy")
  remedialVisitsApproved RemedialVisit[] @relation("RemedialVisitApprovedBy")
  clientLogs   ClientLog[] @relation("ClientLogEncodedBy")
  localPaymentPostings LocalPaymentPosting[] @relation("LocalPaymentPostedBy")

  @@map("users")
}

model Branch {
  id                  Int          @id @default(autoincrement())
  branchName          String       @map("branch_name") @db.VarChar(140)
  branchCode          String       @unique @map("branch_code") @db.VarChar(40)
  publicIp            String?      @map("public_ip") @db.VarChar(80)
  dynamicIp           String?      @map("dynamic_ip") @db.VarChar(160)
  dbHost              String       @map("db_host") @db.VarChar(160)
  dbName              String       @map("db_name") @db.VarChar(120)
  dbUser              String       @map("db_user") @db.VarChar(120)
  encryptedDbPassword String       @map("encrypted_db_password") @db.Text
  status              BranchStatus @default(ACTIVE)
  lastSyncAt          DateTime?    @map("last_sync_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  clients             Client[]
  loans               Loan[]
  coMakers            CoMaker[]
  payments            Payment[]
  localPaymentPostings LocalPaymentPosting[]
  amortizationSchedules AmortizationSchedule[]
  syncLogs            SyncLog[]
  userAccess          UserBranchAccess[]
  remedialAssignments RemedialAssignment[]
  clientLogs          ClientLog[]

  @@map("branches")
}

model Client {
  id              Int       @id @default(autoincrement())
  branchId        Int       @map("branch_id")
  remoteId        String    @map("remote_id") @db.VarChar(80)
  clientId        String?   @map("client_id") @db.VarChar(80)
  fullName        String    @map("full_name") @db.VarChar(180)
  birthdate       DateTime? @db.Date
  contactNumber   String?   @map("contact_number") @db.VarChar(80)
  validIdNumber   String?   @map("valid_id_number") @db.VarChar(120)
  address         String?   @db.VarChar(255)
  remoteUpdatedAt DateTime? @map("remote_updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  branch          Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  loans           Loan[]
  payments        Payment[]
  localPaymentPostings LocalPaymentPosting[]
  amortizationSchedules AmortizationSchedule[]
  logs            ClientLog[]

  @@unique([branchId, remoteId])
  @@index([fullName])
  @@index([birthdate])
  @@index([contactNumber])
  @@index([clientId])
  @@index([validIdNumber])
  @@map("clients")
}

model ClientLog {
  id          Int      @id @default(autoincrement())
  clientId    Int      @map("client_id")
  branchId    Int      @map("branch_id")
  encodedById Int      @map("encoded_by_id")
  logType     String   @default("INQUIRY") @map("log_type") @db.VarChar(60)
  subject     String?  @db.VarChar(180)
  notes       String   @db.Text
  visitAt     DateTime @default(now()) @map("visit_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  encodedBy   User     @relation("ClientLogEncodedBy", fields: [encodedById], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([branchId])
  @@index([encodedById])
  @@index([visitAt])
  @@map("client_logs")
}

model Loan {
  id              Int        @id @default(autoincrement())
  branchId        Int        @map("branch_id")
  clientId        Int        @map("client_id")
  remoteId        String     @map("remote_id") @db.VarChar(80)
  loanNumber      String?    @map("loan_number") @db.VarChar(100)
  loanProduct     String?    @map("loan_product") @db.VarChar(120)
  branchAo        String?    @map("branch_ao") @db.VarChar(160)
  principalAmount Decimal    @default(0) @map("principal_amount") @db.Decimal(14, 2)
  interestRate    Decimal    @default(0) @map("interest_rate") @db.Decimal(8, 4)
  interestAmount  Decimal    @default(0) @map("interest_amount") @db.Decimal(14, 2)
  penaltyAmount   Decimal    @default(0) @map("penalty_amount") @db.Decimal(14, 2)
  terms           String?    @db.VarChar(40)
  paidAmount      Decimal    @default(0) @map("paid_amount") @db.Decimal(14, 2)
  balance         Decimal    @default(0) @db.Decimal(14, 2)
  status          LoanStatus @default(ACTIVE)
  sourceStatusCode Int?      @map("source_status_code")
  sourceStatusName String?   @map("source_status_name") @db.VarChar(80)
  releasedAt      DateTime?  @map("released_at") @db.Date
  maturityAt      DateTime?  @map("maturity_at") @db.Date
  remoteUpdatedAt DateTime?  @map("remote_updated_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  branch          Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  client          Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payments        Payment[]
  localPaymentPostings LocalPaymentPosting[]
  amortizationSchedules AmortizationSchedule[]
  coMakers        CoMaker[]
  remedialAssignment RemedialAssignment?

  @@unique([branchId, remoteId])
  @@index([balance])
  @@index([loanNumber])
  @@index([loanProduct])
  @@map("loans")
}

model UserBranchAccess {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  branchId  Int      @map("branch_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([branchId])
  @@map("user_branch_access")
}

model RemedialAssignment {
  id           Int      @id @default(autoincrement())
  loanId       Int      @unique @map("loan_id")
  branchId     Int      @map("branch_id")
  assignedToId Int      @map("assigned_to_id")
  assignedById Int?     @map("assigned_by_id")
  status       RemedialAssignmentStatus @default(ACTIVE)
  zone         String?  @db.VarChar(120)
  division     String?  @db.VarChar(120)
  province     String?  @db.VarChar(120)
  municipality String? @db.VarChar(120)
  barangay     String?  @db.VarChar(120)
  clientCondition String? @map("client_condition") @db.VarChar(20)
  conditionApprovalStatus String? @map("condition_approval_status") @db.VarChar(20)
  conditionReportedById Int? @map("condition_reported_by_id")
  conditionApprovedById Int? @map("condition_approved_by_id")
  conditionReportedAt DateTime? @map("condition_reported_at")
  conditionApprovedAt DateTime? @map("condition_approved_at")
  assignmentNotes String? @map("assignment_notes") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  loan         Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedTo   User     @relation("RemedialAssignedOfficer", fields: [assignedToId], references: [id], onDelete: Restrict)
  assignedBy   User?    @relation("RemedialAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  visits       RemedialVisit[]

  @@index([branchId])
  @@index([assignedToId])
  @@index([status])
  @@map("remedial_assignments")
}

model RemedialVisit {
  id              Int      @id @default(autoincrement())
  assignmentId    Int      @map("assignment_id")
  scheduledDate   DateTime @map("scheduled_date") @db.Date
  scheduleNotes   String?  @map("schedule_notes") @db.Text
  status          RemedialVisitStatus @default(PENDING_APPROVAL)
  visitNotes      String?  @map("visit_notes") @db.Text
  negotiationNotes String? @map("negotiation_notes") @db.Text
  promisedAmount  Decimal @default(0) @map("promised_amount") @db.Decimal(14, 2)
  paidAmount      Decimal @default(0) @map("paid_amount") @db.Decimal(14, 2)
  nextVisitDate   DateTime? @map("next_visit_date") @db.Date
  createdById     Int?     @map("created_by_id")
  approvedById    Int?     @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  assignment      RemedialAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  createdBy       User? @relation("RemedialVisitCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy      User? @relation("RemedialVisitApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([assignmentId])
  @@index([scheduledDate])
  @@index([status])
  @@map("remedial_visits")
}

model CoMaker {
  id              Int      @id @default(autoincrement())
  branchId        Int      @map("branch_id")
  loanId          Int      @map("loan_id")
  remoteId        String   @map("remote_id") @db.VarChar(140)
  name            String   @db.VarChar(180)
  clientRemoteId  String?  @map("client_remote_id") @db.VarChar(80)
  contactNumber   String?  @map("contact_number") @db.VarChar(80)
  validIdNumber   String?  @map("valid_id_number") @db.VarChar(120)
  address         String?  @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  loan            Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([branchId, remoteId])
  @@index([name])
  @@index([loanId])
  @@index([clientRemoteId])
  @@index([validIdNumber])
  @@map("co_makers")
}

model AmortizationSchedule {
  id                Int      @id @default(autoincrement())
  branchId          Int      @map("branch_id")
  clientId          Int?     @map("client_id")
  loanId            Int      @map("loan_id")
  remoteId          String   @map("remote_id") @db.VarChar(80)
  amortNo           Int      @map("amort_no")
  amortDate         DateTime? @map("amort_date") @db.Date
  principalBalance  Decimal  @default(0) @map("principal_balance") @db.Decimal(14, 2)
  interestBalance   Decimal  @default(0) @map("interest_balance") @db.Decimal(14, 2)
  principalAmort    Decimal  @default(0) @map("principal_amort") @db.Decimal(14, 2)
  interestAmort     Decimal  @default(0) @map("interest_amort") @db.Decimal(14, 2)
  totalAmort        Decimal  @default(0) @map("total_amort") @db.Decimal(14, 2)
  paidPrincipal     Decimal  @default(0) @map("paid_principal") @db.Decimal(14, 2)
  paidInterest      Decimal  @default(0) @map("paid_interest") @db.Decimal(14, 2)
  paidTotal         Decimal  @default(0) @map("paid_total") @db.Decimal(14, 2)
  paidStatus        Int?     @map("paid_status")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  branch            Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  client            Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  loan              Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([branchId, remoteId])
  @@index([clientId])
  @@index([loanId])
  @@index([amortDate])
  @@map("amortization_schedules")
}

model Payment {
  id              Int       @id @default(autoincrement())
  branchId        Int       @map("branch_id")
  clientId        Int       @map("client_id")
  loanId          Int?      @map("loan_id")
  remoteId        String    @map("remote_id") @db.VarChar(80)
  amount          Decimal   @default(0) @db.Decimal(14, 2)
  paidAt          DateTime? @map("paid_at") @db.Date
  remoteUpdatedAt DateTime? @map("remote_updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  branch          Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  loan            Loan?     @relation(fields: [loanId], references: [id], onDelete: SetNull)

  @@unique([branchId, remoteId])
  @@index([paidAt])
  @@map("payments")
}

model LocalPaymentPosting {
  id                    Int      @id @default(autoincrement())
  branchId              Int      @map("branch_id")
  clientId              Int      @map("client_id")
  loanId                Int      @map("loan_id")
  postedById            Int      @map("posted_by_id")
  mode                  String   @db.VarChar(20)
  prNumber              String?  @map("pr_number") @db.VarChar(80)
  orNumber              String?  @map("or_number") @db.VarChar(80)
  paymentType           String   @default("0-Cash") @map("payment_type") @db.VarChar(80)
  chequeNo              String?  @map("cheque_no") @db.VarChar(120)
  glCode                String?  @map("gl_code") @db.VarChar(120)
  memoType              String?  @map("memo_type") @db.VarChar(120)
  paymentDate           DateTime @map("payment_date") @db.Date
  principalAmount       Decimal  @default(0) @map("principal_amount") @db.Decimal(14, 2)
  interestAmount        Decimal  @default(0) @map("interest_amount") @db.Decimal(14, 2)
  penaltyAmount         Decimal  @default(0) @map("penalty_amount") @db.Decimal(14, 2)
  pdiAmount             Decimal  @default(0) @map("pdi_amount") @db.Decimal(14, 2)
  otherChargesAmount    Decimal  @default(0) @map("other_charges_amount") @db.Decimal(14, 2)
  totalAmount           Decimal  @default(0) @map("total_amount") @db.Decimal(14, 2)
  accountOfficerChanged Boolean  @default(false) @map("account_officer_changed")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  branch                Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  loan                  Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  postedBy              User     @relation("LocalPaymentPostedBy", fields: [postedById], references: [id], onDelete: Restrict)

  @@index([branchId])
  @@index([clientId])
  @@index([loanId])
  @@index([postedById])
  @@index([paymentDate])
  @@map("local_payment_postings")
}

model SyncLog {
  id             Int        @id @default(autoincrement())
  branchId       Int?       @map("branch_id")
  status         SyncStatus
  startedAt      DateTime   @default(now()) @map("started_at")
  finishedAt     DateTime?  @map("finished_at")
  clientsPulled  Int        @default(0) @map("clients_pulled")
  loansPulled    Int        @default(0) @map("loans_pulled")
  paymentsPulled Int        @default(0) @map("payments_pulled")
  branchesCompleted Int     @default(0) @map("branches_completed")
  branchesFailed    Int     @default(0) @map("branches_failed")
  message        String?    @db.Text
  branch         Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([startedAt])
  @@map("sync_logs")
}
